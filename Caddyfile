{
	admin off
	# Railway termine déjà TLS en amont : Caddy sert en clair derrière son proxy.
	auto_https off
}

:{$PORT:8080} {
	root * /srv
	encode zstd gzip

	# Repli SPA : toute route inconnue rend index.html, sinon un rechargement
	# sur /citoyen/xxx renverrait un 404.
	try_files {path} /index.html
	file_server

	# Les assets portent un hash dans leur nom : cache long. L'index, lui,
	# doit être revalidé à chaque visite pour livrer la nouvelle version.
	header /assets/* Cache-Control "public, max-age=31536000, immutable"
	header /index.html Cache-Control "no-cache"
}
